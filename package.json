{
  "name": "sopla-el-cartucho-jsconf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JSConf España 2026 retro site — Astro UI + deterministic asset pipeline",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test test/*.test.js",
    "fetch-agenda": "tsx scripts/fetch-agenda.ts",
    "generate:avatars": "node scripts-generate-avatars.mjs",
    "generate:avatars:demo": "node scripts-generate-avatars.mjs --demo",
    "generate:assets": "tsx scripts/generate-assets.ts",
    "generate:covers": "tsx scripts/generate-covers.ts",
    "generate:all": "npm run generate:assets && npm run generate:covers"
  },
  "dependencies": {
    "sharp": "^0.33.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "astro": "^5.18.1",
    "cheerio": "^1.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
