---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const avatarSrc = `${base}/assets/avatars/gisela-torres-profile.jpg`;

const skills = [
  { name: 'AI', value: 80 },
  { name: 'CLOUD', value: 90 },
  { name: 'DEVOPS', value: 85 },
  { name: 'CODE', value: 90 },
  { name: 'YOUTUBE', value: 95 },
];

const socials = [
  { label: 'BLOG', href: 'https://www.returngis.net', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2m-5.15 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M14.34 14H9.66c-.1-.66-.16-1.32-.16-2s.06-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2M12 19.96c-.83-1.2-1.5-2.53-1.91-3.96h3.82c-.41 1.43-1.08 2.76-1.91 3.96M8 8H5.08A7.92 7.92 0 0 1 9.4 4.44C8.8 5.55 8.35 6.75 8 8m-2.92 8H8c.35 1.25.8 2.45 1.4 3.56A8 8 0 0 1 5.08 16m-.82-2C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2M12 4.03c.83 1.2 1.5 2.54 1.91 3.97h-3.82c.41-1.43 1.08-2.77 1.91-3.97M18.92 8h-2.95a15.7 15.7 0 0 0-1.38-3.56c1.84.63 3.37 1.9 4.33 3.56M12 2C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2"/></svg>' },
  { label: 'YOUTUBE', href: 'https://youtube.com/@returngis', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="m10 15l5.19-3L10 9zm11.56-7.83c.13.47.22 1.1.28 1.9c.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83c-.25.9-.83 1.48-1.73 1.73c-.47.13-1.33.22-2.65.28c-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44c-.9-.25-1.48-.83-1.73-1.73c-.13-.47-.22-1.1-.28-1.9c-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83c.25-.9.83-1.48 1.73-1.73c.47-.13 1.33-.22 2.65-.28c1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44c.9.25 1.48.83 1.73 1.73"/></svg>' },
  { label: 'GITHUB', href: 'https://github.com/0GiS0', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/></svg>' },
  { label: 'X', href: 'https://x.com/0GiS0', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M22.46 6c-.77.35-1.6.58-2.46.69c.88-.53 1.56-1.37 1.88-2.38c-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29c0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15c0 1.49.75 2.81 1.91 3.56c-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.2 4.2 0 0 1-1.93.07a4.28 4.28 0 0 0 4 2.98a8.52 8.52 0 0 1-5.33 1.84q-.51 0-1.02-.06C3.44 20.29 5.7 21 8.12 21C16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56c.84-.6 1.56-1.36 2.14-2.23"/></svg>' },
  { label: 'LINKEDIN', href: 'https://www.linkedin.com/in/giselatorresbuitrago/', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"/></svg>' },
];
---

<BaseLayout
  title="About Me — Sopla el Cartucho"
  description="Gisela Torres — Global Blackbelt at Microsoft. Speaker at JSConf España 2026."
  currentPage="about"
>
  <section class="about-page">
    <h1 class="page-title">
      <span class="title-prefix" aria-hidden="true">►</span> PLAYER 1
    </h1>

    <div class="about-grid">
      <!-- Character card -->
      <div class="char-card pixel-border">
        <div class="char-header">
          <div class="avatar-frame pixel-border">
            <img
              src={avatarSrc}
              alt="Gisela Torres"
              class="avatar-img"
              width="120"
              height="120"
            />
          </div>
          <div class="char-meta">
            <h2 class="char-name">GISELA TORRES</h2>
            <dl class="char-stats-list">
              <div class="stat-row">
                <dt>CLASS</dt>
                <dd>GLOBAL BLACKBELT</dd>
              </div>
              <div class="stat-row">
                <dt>GUILD</dt>
                <dd>MICROSOFT</dd>
              </div>
              <div class="stat-row">
                <dt>ALIAS</dt>
                <dd>0GiS0</dd>
              </div>
            </dl>
          </div>
        </div>

        <p class="char-bio">
          Apasionada de la tecnología, la inteligencia artificial y el desarrollo de software.
          Comparte conocimientos a través de su canal de YouTube ReturnGis y su blog returngis.net.
          Fue Microsoft MVP antes de unirse a Microsoft y actualmente es Docker Captain.
        </p>

        <!-- Skills bars -->
        <div class="skills-section">
          <h3 class="skills-title">⚔ SKILLS</h3>
          {skills.map((s) => (
            <div class="skill-row">
              <span class="skill-label">{s.name}</span>
              <div class="skill-track" title={`${s.value}%`}>
                <div class="skill-fill" style={`width:${s.value}%`} />
              </div>
              <span class="skill-pct">{s.value}%</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Talk & social column -->
      <div class="side-col">
        <!-- Current quest -->
        <div class="quest-card pixel-border">
          <h3 class="quest-title">🎮 CURRENT QUEST</h3>
          <p class="quest-name">"Cómo la IA puede ayudarnos con nuestros desarrollos en JavaScript"</p>
          <p class="quest-desc">
            Charla en JSConf España 2026 sobre cómo los agentes de IA y GitHub Copilot pueden potenciar tu flujo de desarrollo en JavaScript.
          </p>
        </div>

        <!-- Social links -->
        <div class="social-card pixel-border">
          <h3 class="social-title">📡 CONNECT</h3>
          <div class="social-grid">
            {socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn"
              >
                <span class="social-icon" set:html={s.svg} />
                <span class="social-label">{s.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Page layout ── */
  .about-page {
    padding: 24px 20px 32px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text);
    text-align: center;
    margin: 0 0 24px;
    text-shadow: 2px 2px 0 rgba(116, 86, 59, 0.25);
  }

  .title-prefix {
    color: var(--accent);
  }

  /* ── Grid ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Shared border helper ── */
  .pixel-border {
    border: 3px solid var(--border-strong);
    box-shadow:
      4px 4px 0 rgba(50, 35, 14, 0.45),
      inset 0 1px 0 rgba(255, 245, 180, 0.35);
    background: var(--panel);
  }

  /* ── Character card ── */
  .char-card {
    padding: 18px;
  }

  .char-header {
    display: flex;
    gap: 16px;
    margin-bottom: 14px;
  }

  .avatar-frame {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    padding: 4px;
    background: var(--panel2);
    overflow: hidden;
  }

  .avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 2px;
  }

  .char-meta {
    flex: 1;
    min-width: 0;
  }

  .char-name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--accent-dark);
    margin: 0 0 10px;
    line-height: 1.4;
  }

  /* ── Stats list ── */
  .char-stats-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-row {
    display: flex;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .stat-row dt {
    color: var(--muted);
    min-width: 52px;
  }

  .stat-row dd {
    margin: 0;
    color: var(--text);
    font-weight: bold;
  }

  /* ── Bio ── */
  .char-bio {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.35;
    color: var(--text);
    margin: 0 0 16px;
    padding: 10px 12px;
    background: var(--panel2);
    border: 2px solid var(--border);
  }

  /* ── Skills ── */
  .skills-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .skills-title {
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: var(--text);
    margin: 0 0 4px;
  }

  .skill-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .skill-label {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--muted);
    min-width: 64px;
  }

  .skill-track {
    flex: 1;
    height: 14px;
    background: var(--panel2);
    border: 2px solid var(--border);
    position: relative;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(180deg, #f8c84a, #d48c20);
    image-rendering: pixelated;
  }

  .skill-pct {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
    min-width: 36px;
    text-align: right;
  }

  /* ── Side column ── */
  .side-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Quest card ── */
  .quest-card {
    padding: 16px;
  }

  .quest-title {
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: var(--text);
    margin: 0 0 10px;
  }

  .quest-name {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--accent-dark);
    margin: 0 0 8px;
    line-height: 1.5;
  }

  .quest-desc {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.35;
    color: var(--text);
    margin: 0;
  }

  /* ── Social card ── */
  .social-card {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .social-title {
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: var(--text);
    margin: 0 0 12px;
  }

  .social-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(180deg, #f8c84a, #d48c20);
    border: 3px solid var(--border-strong);
    box-shadow:
      3px 3px 0 rgba(50, 35, 14, 0.6),
      inset 0 1px 0 rgba(255, 245, 180, 0.5);
    padding: 8px 14px;
    font-family: var(--font-display);
    font-size: 0.55rem;
    color: #1e140a;
    text-decoration: none;
    transition: transform 0.1s, box-shadow 0.1s;
    cursor: pointer;
  }

  .social-btn:hover {
    background: linear-gradient(180deg, #ffd85a, #e09a28);
    box-shadow:
      2px 2px 0 rgba(50, 35, 14, 0.6),
      inset 0 1px 0 rgba(255, 245, 180, 0.5);
    transform: translate(1px, 1px);
  }

  .social-btn:active {
    background: linear-gradient(180deg, #b87818, #8a5810);
    box-shadow:
      inset 2px 2px 0 rgba(50, 35, 14, 0.5),
      inset -1px -1px 0 rgba(255, 245, 180, 0.15);
    transform: translate(2px, 2px);
    color: #f5e0b0;
  }

  .social-icon {
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .social-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .about-page {
      padding: 16px 10px 24px;
    }

    .page-title {
      font-size: 1rem;
    }

    .char-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .char-name {
      font-size: 0.7rem;
    }

    .char-stats-list {
      align-items: center;
    }

    .stat-row {
      justify-content: center;
    }
  }
</style>
