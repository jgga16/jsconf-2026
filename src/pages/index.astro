---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartridgeCard from '../components/CartridgeCard.astro';
import BreakCartridge from '../components/BreakCartridge.astro';
import GameBoy from '../components/GameBoy.astro';
import { talksWithAssets, event } from '../lib/talks';

// Render agenda as cartridges; skip ceremonies without speakers
const agendaItems = talksWithAssets
  .filter((t) => {
    if (t.type === 'ceremony' && (!t.speakers || t.speakers.length === 0)) return false;
    return true;
  })
  .sort((a, b) => a.time.start.localeCompare(b.time.start));

const speakerTalks = agendaItems.filter((t) => t.type !== 'break');

// Hero speaker shown in the console monitor
const heroIndex = 0;
const heroTalk = speakerTalks[heroIndex] ?? speakerTalks[0] ?? agendaItems[0];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawHeroAvatar = heroTalk?.assets?.avatar8bit ?? '/placeholders/avatar.svg';
const heroAvatar = rawHeroAvatar.startsWith('/') ? `${base}${rawHeroAvatar}` : rawHeroAvatar;

// Card rows: show full agenda in chronological order (hero will also be a cartridge)
const firstRow = agendaItems.slice(0, 3);
const remainingTalks = agendaItems.slice(3);

const qrCodeSrc = `${base}/assets/qr-code.png`;
---

<BaseLayout
  title={`${event.name} — Sopla el Cartucho`}
  description={`${event.name} (${event.date}) — ${event.venue}.`}
>
  <div class="desktop-wrap">
    <div class="desktop-window pixel-frame">
      <!-- Window chrome -->
      <div class="window-chrome">
        <div class="chrome-left">
          <div class="chrome-left-inner">
            <span class="chrome-star" aria-hidden="true">★</span>
            <span class="chrome-menu">Back · Forward · Home · Reload</span>
          </div>
          <div class="chrome-buttons" aria-hidden="true">
            <span class="btn-min">▬</span>
            <span class="btn-max">☐</span>
            <span class="btn-close">✕</span>
          </div>
        </div>
        <div class="chrome-nav-row">
          <span class="nav-arrows" aria-hidden="true">← → ⊕</span>
          <div class="address-bar"><a href="https://www.returngis.net/" target="_blank" rel="noopener">https://www.returngis.net</a></div>
        </div>
      </div>

      <!-- Hero: nav + console (left) | title + first card row (right) -->
      <section class="hero" id="home" aria-labelledby="site-title">
        <div class="hero-left">
          <nav class="side-nav" aria-label="Primary">
            <a href="#home">HOME</a>
            <a href="#about">ABOUT</a>
            <a href="#speakers">SPEAKERS</a>
            <a href="#contact">CONTACT</a>
          </nav>

          <GameBoy avatarSrc={heroAvatar} name={heroTalk?.speakers?.[0]?.name} />
        </div>

        <div class="hero-right">
          <div class="hero-title-row">
            <div class="hero-title">
              <h1 id="site-title">Sopla el cartucho</h1>
              <p class="event-name">{event.name}</p>
            </div>
            <div class="qr-code-wrapper" title="Escanea para ver en móvil">
              <img src={qrCodeSrc} alt="QR Code - Escanea para ver en móvil" class="qr-code" />
              <span class="qr-label">📱 ESCANEA</span>
            </div>
          </div>

          <div class="hero-cards" id="speakers">
            {firstRow.map((talk) => (
              talk.type === 'break' ? (
                <BreakCartridge talk={talk} />
              ) : (
                <CartridgeCard talk={talk} />
              )
            ))}
          </div>
        </div>
      </section>

      <!-- Remaining speaker rows -->
      <section class="speakers-panel" aria-label="More speakers">
        <div class="cartridge-grid">
          {remainingTalks.map((talk) => (
            talk.type === 'break' ? (
              <BreakCartridge talk={talk} />
            ) : (
              <CartridgeCard talk={talk} />
            )
          ))}
        </div>
      </section>

      <footer class="site-footer" id="contact">
        <p>© 2026 RETROGAMES</p>
        <span aria-hidden="true">|</span>
        <p>EMAIL</p>
        <span aria-hidden="true">|</span>
        <p>TERMS OF SERVICE</p>
      </footer>
    </div>
  </div>

  <script>
    // Interactive console: click cartridge to load speaker in GameBoy
    document.addEventListener('DOMContentLoaded', () => {
      const screen = document.getElementById('gameboy-screen') as HTMLImageElement;
      const cartridges = document.querySelectorAll('.card-wrap[data-talk-id]');
      const display = document.querySelector('.display') as HTMLElement;
      
      if (!screen || cartridges.length === 0 || !display) return;

      // Create GAME OVER overlay
      const gameOverOverlay = document.createElement('div');
      gameOverOverlay.className = 'game-over-overlay';
      gameOverOverlay.innerHTML = `
        <div class="game-over-text">GAME</div>
        <div class="game-over-text">OVER</div>
        <div class="game-over-hint">INSERT CARTRIDGE</div>
      `;
      display.appendChild(gameOverOverlay);

      // 8-bit Game Over sound using Web Audio API
      function playGameOverSound() {
        const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const notes = [523, 392, 330, 262]; // C5, G4, E4, C4 - descending
        const duration = 0.2;
        
        notes.forEach((freq, i) => {
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          
          osc.type = 'square'; // 8-bit sound
          osc.frequency.value = freq;
          osc.connect(gain);
          gain.connect(audioCtx.destination);
          
          const startTime = audioCtx.currentTime + (i * duration);
          gain.gain.setValueAtTime(0.1, startTime);
          gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
          
          osc.start(startTime);
          osc.stop(startTime + duration);
        });
      }

      // Play "cartridge inserted" sound
      function playInsertSound() {
        const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const notes = [262, 330, 392, 523]; // C4, E4, G4, C5 - ascending (victory!)
        const duration = 0.1;
        
        notes.forEach((freq, i) => {
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          
          osc.type = 'square';
          osc.frequency.value = freq;
          osc.connect(gain);
          gain.connect(audioCtx.destination);
          
          const startTime = audioCtx.currentTime + (i * duration);
          gain.gain.setValueAtTime(0.08, startTime);
          gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
          
          osc.start(startTime);
          osc.stop(startTime + duration);
        });
      }

      // Show GAME OVER state
      function showGameOver() {
        gameOverOverlay.classList.add('visible');
        screen.style.opacity = '0.2';
        playGameOverSound();
      }

      // Hide GAME OVER state
      function hideGameOver() {
        gameOverOverlay.classList.remove('visible');
        screen.style.opacity = '1';
      }

      // Find talk happening NOW based on current time
      function getCurrentTalk(): HTMLElement | null {
        const now = new Date();
        const currentTime = now.getHours().toString().padStart(2, '0') + ':' + 
                           now.getMinutes().toString().padStart(2, '0');
        
        for (const card of cartridges) {
          const start = card.getAttribute('data-time-start');
          const end = card.getAttribute('data-time-end');
          if (start && end && currentTime >= start && currentTime < end) {
            return card as HTMLElement;
          }
        }
        return null;
      }

      // Select a cartridge and update GameBoy screen
      function selectCartridge(card: HTMLElement, playSound = true) {
        // Hide game over
        hideGameOver();
        
        // Remove selected from all
        cartridges.forEach(c => c.classList.remove('is-selected'));
        
        // Add selected to clicked card
        card.classList.add('is-selected');
        
        // Update GameBoy screen with smooth transition
        const avatar = card.getAttribute('data-avatar');
        const speaker = card.getAttribute('data-speaker');
        
        if (avatar && screen) {
          screen.style.opacity = '0';
          setTimeout(() => {
            screen.src = avatar;
            screen.alt = speaker || '';
            screen.style.opacity = '1';
            if (playSound) playInsertSound();
          }, 150);
        }

        // Scroll cartridge into view if needed
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      // Add click handlers to all cartridges
      cartridges.forEach(card => {
        card.addEventListener('click', () => {
          selectCartridge(card as HTMLElement, true);
        });
        
        // Add cursor pointer style
        (card as HTMLElement).style.cursor = 'pointer';
      });

      // On load: select current talk or show GAME OVER
      // Debug: add ?gameover=true to URL to force GAME OVER state
      const urlParams = new URLSearchParams(window.location.search);
      const forceGameOver = urlParams.get('gameover') === 'true';
      
      const currentTalk = forceGameOver ? null : getCurrentTalk();
      if (currentTalk) {
        selectCartridge(currentTalk, false);
      } else {
        // No talk in progress - GAME OVER!
        const firstCard = cartridges[0] as HTMLElement;
        if (firstCard) {
          firstCard.classList.add('is-selected');
        }
        // Delay to let boot animation complete first
        setTimeout(() => {
          showGameOver();
        }, 4000);
      }
    });
  </script>
</BaseLayout>
