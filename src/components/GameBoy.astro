---
/*
 * Game Boy CSS art based on work by Brandon
 * https://codepen.io/brundolf/pen/beagbQ
 * MIT License — Copyright (c) Brandon
 */
type Props = {
  avatarSrc: string;
  name?: string;
};
const { avatarSrc, name = '' } = Astro.props;

const dots = [
  'p','o','c','o','c','o','c','p',
  'o','c','o','c','o','c','o','c',
  'c','o','c','o','c','o','c','o',
  'o','c','o','c','o','c','o','c',
  'c','o','c','o','c','o','c','o',
  'o','c','o','c','o','c','o','c',
  'c','o','c','o','c','o','c','o',
  'p','c','o','c','o','c','o','p',
] as const;
---

<div class="gb-wrap" aria-hidden="true">
  <div class="gameboy">

    <div class="screen-area">

      <div class="power">
        <div class="indicator">
          <!-- LED starts dim; animation powers it on -->
          <div class="led"></div>
          <span class="arc" style="z-index:2"></span>
          <span class="arc" style="z-index:1"></span>
          <span class="arc" style="z-index:0"></span>
        </div>
        POWER
      </div>

      <div class="display">
        <!-- Avatar underneath — always rendered, boot overlay covers it -->
        <img src={avatarSrc} alt={name} class="screen-img" id="gameboy-screen" />

        <!-- Boot sequence overlay -->
        <div class="boot-overlay">
          <!-- Standby hint (visible before power-on) -->
          <div class="boot-hint">
            <div class="boot-hint-icon">⏻</div>
            <div class="boot-hint-text">POWER ON</div>
          </div>

          <!-- White LCD flicker on power-on -->
          <div class="boot-flash"></div>

          <!-- "JS Conf / España / 2026" slides in like the Nintendo logo -->
          <div class="boot-logo">
            <div class="boot-jsconf">JS<span class="boot-space"> </span>Conf</div>
            <div class="boot-espana">España</div>
            <div class="boot-divider"></div>
            <div class="boot-year">2026</div>
          </div>
        </div>
      </div>

      <div class="gb-label">
        <span class="gb-title">GAME BOY</span>
        <span class="gb-subtitle">
          <span class="lc">C</span><span class="lo1">O</span><span class="ll">L</span><span class="lo2">O</span><span class="lr">R</span>
        </span>
      </div>

    </div>

    <div class="nintendo-label">Nintendo</div>

    <div class="controls">
      <div class="dpad">
        <div class="dpad-btn dpad-up">▲</div>
        <div class="dpad-btn dpad-right">▶</div>
        <div class="dpad-btn dpad-down">▼</div>
        <div class="dpad-btn dpad-left">◀</div>
        <div class="dpad-middle"></div>
      </div>
      <div class="ab-group">
        <div class="btn-b">B</div>
        <div class="btn-a">A</div>
      </div>
    </div>

    <div class="start-select">
      <div class="btn-select">SELECT</div>
      <div class="btn-start">START</div>
    </div>

    <div class="speaker">
      {dots.map((d) => (
        <div class={
          d === 'p' ? 'dot dot-placeholder' :
          d === 'o' ? 'dot dot-open' :
                      'dot dot-closed'
        }></div>
      ))}
    </div>

  </div>
</div>

<style>
  /* ─────────────────────────────────────────────────
     Boot sequence keyframes
  ───────────────────────────────────────────────── */

  /* LED: amber standby pulse while off */
  @keyframes led-standby {
    0%, 100% { background-color: #300808; box-shadow: none; }
    50%      { background-color: #6a1c04; box-shadow: 0 0 5px rgba(220,80,0,0.5); }
  }

  /* LED: powers on after click */
  @keyframes led-power-on {
    from { background-color: #300808; box-shadow: none; }
    to   { background-color: #ca1a21; box-shadow: 0px 0px 10px #ff552e; }
  }

  /* Screen LCD flicker when powered on */
  @keyframes screen-flash {
    0%   { opacity: 0; }
    15%  { opacity: 1; background: #e0ffe0; }
    30%  { opacity: 0.2; }
    50%  { opacity: 0.9; background: #fff; }
    70%  { opacity: 0.15; }
    100% { opacity: 0; }
  }

  /* Boot logo slides in from above (like Nintendo logo) */
  @keyframes logo-slide-in {
    from  { transform: translateY(-105px); opacity: 0; }
    10%   { opacity: 1; }
    to    { transform: translateY(0);      opacity: 1; }
  }

  /* Boot overlay fades out to reveal avatar */
  @keyframes boot-fade-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* Standby hint pulse */
  @keyframes hint-pulse {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 0.6; }
  }

  /* ─────────────────────────────────────────────────
     Scale wrapper
  ───────────────────────────────────────────────── */
  .gb-wrap {
    width: 252px;
    height: 411px;
    position: relative;
    flex-shrink: 0;
  }

  /* ─────────────────────────────────────────────────
     Game Boy body
  ───────────────────────────────────────────────── */
  .gameboy {
    position: absolute;
    top: 0;
    left: 0;
    transform: scale(0.72);
    transform-origin: top left;
    width: 350px;
    height: 570px;
    border-radius: 20px;
    padding: 20px;
    background-color: #4f50db;
    box-shadow: 0px -5px 0px #0d0e51, 0px 5px 0px #3d38b5;
    font-family: sans-serif;
    user-select: none;
    cursor: default;
  }

  .gameboy::after {
    content: '';
    display: block;
    position: absolute;
    top: calc(100% - 34px);
    left: 5px;
    width: calc(100% - 10px);
    height: 50px;
    border-radius: 50%;
    background-color: #4f50db;
    box-shadow: 0px 5px 0px #3d38b5;
    border-bottom: 2px solid #9998eb;
  }

  /* ─────────────────────────────────────────────────
     Screen housing
  ───────────────────────────────────────────────── */
  .screen-area {
    position: relative;
    padding: 35px 50px 5px 50px;
    border-radius: 15px;
    background-color: #23252d;
    color: #67879a;
    box-shadow: 0px 2px 0px black, 0px -2px 0px black,
                -2px 0px 0px black, 2px 0px 0px black;
  }

  .screen-area::after {
    content: '';
    display: block;
    position: absolute;
    top: calc(100% - 20px);
    left: 5px;
    width: calc(100% - 10px);
    height: 30px;
    border-radius: 50%;
    background-color: #23252d;
    box-shadow: 0px 2px 0px black;
  }

  /* ─────────────────────────────────────────────────
     Power button — clickable, standby state
  ───────────────────────────────────────────────── */
  .power {
    position: absolute;
    display: block;
    width: 50px;
    left: 0;
    top: 80px;
    font-size: 10px;
    letter-spacing: -0.5px;
    text-align: center;
    cursor: pointer;
    z-index: 20;
  }

  .power:hover .led {
    background-color: #8a2008;
    box-shadow: 0 0 7px rgba(255, 80, 0, 0.7);
  }

  .indicator { line-height: 14px; }

  /* LED: standby amber pulse by default */
  .led {
    position: relative;
    display: inline-block;
    background-color: #300808;
    box-shadow: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    z-index: 5;
    animation: led-standby 2s ease-in-out infinite;
  }

  /* LED: boot animation once powered on */
  .gb-wrap.is-on .led {
    animation: led-power-on 0.5s ease-out 0.3s both;
  }

  .arc {
    position: relative;
    display: inline-block;
    width: 8px;
    height: 8px;
    margin-left: -2px;
  }

  .arc::before {
    position: absolute;
    left: 3px;
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #67879a;
  }

  .arc::after {
    position: absolute;
    left: 0;
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #23252d;
  }

  /* ─────────────────────────────────────────────────
     LCD screen
  ───────────────────────────────────────────────── */
  .display {
    position: relative;
    background-color: #0a0a0a; /* starts black (off) */
    height: 190px;
    width: 210px;
    border-radius: 3px;
    margin-bottom: 15px;
    overflow: hidden;
  }

  .screen-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    display: block;
    filter: sepia(15%) hue-rotate(60deg) saturate(0.85) brightness(0.85) contrast(1.1);
    /* z-index below boot overlay */
    z-index: 0;
  }

  /* ─────────────────────────────────────────────────
     Boot overlay — covers avatar until sequence ends
  ───────────────────────────────────────────────── */
  .boot-overlay {
    position: absolute;
    inset: 0;
    background: #000;
    z-index: 10;
    pointer-events: none;
    overflow: hidden;
    /* Animation only starts after .is-on is added */
  }

  .gb-wrap.is-on .boot-overlay {
    animation: boot-fade-out 0.7s ease-in 3.4s forwards;
  }

  /* ─────────────────────────────────────────────────
     Standby hint — visible before power-on
  ───────────────────────────────────────────────── */
  .boot-hint {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    z-index: 15;
    animation: hint-pulse 2s ease-in-out infinite;
    pointer-events: none;
  }

  /* Hide hint once powered on */
  .gb-wrap.is-on .boot-hint {
    display: none;
  }

  .boot-hint-icon {
    font-size: 28px;
    color: rgba(180, 140, 100, 0.5);
    line-height: 1;
  }

  .boot-hint-text {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    color: rgba(180, 140, 100, 0.4);
    letter-spacing: 2px;
  }

  /* White LCD flicker at power-on */
  .boot-flash {
    position: absolute;
    inset: 0;
    background: #d0ffd0;
    opacity: 0;
    z-index: 2;
  }

  .gb-wrap.is-on .boot-flash {
    animation: screen-flash 0.7s ease-out 0.35s forwards;
  }

  /* ─────────────────────────────────────────────────
     Boot logo — "JS Conf / España / 2026"
  ───────────────────────────────────────────────── */
  .boot-logo {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
    gap: 4px;
    /* Hidden until .is-on */
    transform: translateY(-105px);
    opacity: 0;
  }

  .gb-wrap.is-on .boot-logo {
    animation: logo-slide-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) 1.1s both;
  }

  .boot-jsconf {
    font-family: 'Press Start 2P', monospace;
    font-size: 18px;
    color: #ffffff;
    letter-spacing: 2px;
    text-shadow:
      2px 2px 0 #3a3a80,
      0 0 12px rgba(120, 120, 255, 0.6);
    line-height: 1;
  }

  .boot-space {
    display: inline-block;
    width: 6px;
  }

  .boot-espana {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    color: #aaaacc;
    letter-spacing: 3px;
    line-height: 1;
    margin-top: 2px;
  }

  .boot-divider {
    width: 120px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      #5555cc 20%,
      #aaaaff 50%,
      #5555cc 80%,
      transparent 100%
    );
    margin: 6px 0;
  }

  .boot-year {
    font-family: 'Press Start 2P', monospace;
    font-size: 22px;
    color: #ffffff;
    letter-spacing: 4px;
    text-shadow:
      3px 3px 0 #1a1a60,
      0 0 16px rgba(100, 100, 255, 0.8);
    line-height: 1;
  }

  /* ─────────────────────────────────────────────────
     Reduced motion: skip animation, show avatar immediately
  ───────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .led {
      animation: none !important;
      background-color: #ca1a21;
      box-shadow: 0px 0px 10px #ff552e;
    }
    .boot-overlay { display: none; }
    .boot-flash   { display: none; }
    .display { background-color: #929d97; }
  }

  /* ─────────────────────────────────────────────────
     "GAME BOY COLOR" label
  ───────────────────────────────────────────────── */
  .gb-label {
    position: relative;
    text-align: center;
    font-size: 20px;
    z-index: 5;
  }

  .gb-title {
    display: inline;
    font-weight: bold;
    font-style: italic;
  }

  .gb-subtitle {
    display: inline;
    font-family: "Comic Sans MS", cursive;
    font-weight: bold;
    font-size: 22px;
    letter-spacing: -1px;
  }

  .lc  { display: inline-block; color: #aa2058; }
  .lo1 { display: inline-block; color: #605bd9; font-size: 20px; }
  .ll  { display: inline-block; color: #78b930; transform: rotateZ(-10deg); }
  .lo2 { display: inline-block; color: #b6b524; font-size: 20px; }
  .lr  { display: inline-block; color: #317aaf; }

  /* ─────────────────────────────────────────────────
     Nintendo badge
  ───────────────────────────────────────────────── */
  .nintendo-label {
    padding: 0 5px;
    width: 82px;
    color: #3436bf;
    font-weight: bold;
    text-align: center;
    margin: 30px auto 0;
    border: 2px solid #3436bf;
    border-radius: 11px;
    text-shadow: 0px -2px 1px #6b67ed;
    box-shadow: 0px -2px 1px #6b67ed;
  }

  /* ─────────────────────────────────────────────────
     Controls
  ───────────────────────────────────────────────── */
  .controls {
    display: flex;
    justify-content: space-between;
  }

  .dpad {
    position: relative;
    display: inline-block;
    width: 90px;
    height: 90px;
    z-index: 5;
  }

  .dpad-btn {
    width: 33%;
    height: 33%;
    position: absolute;
    background-color: #565e6a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #333a4a;
  }

  .dpad-up {
    top: 4px; left: 33%;
    border: 4px solid black; border-bottom: none;
    border-radius: 5px 5px 0 0;
  }

  .dpad-right {
    top: 33%; left: calc(66% - 4px);
    border: 4px solid black; border-left: none;
    border-radius: 0 5px 5px 0;
    box-shadow: 0px -2px 0px #888 inset;
  }

  .dpad-down {
    top: calc(66% - 4px); left: 33%;
    border: 4px solid black; border-top: none;
    border-radius: 0 0 5px 5px;
    box-shadow: 0px -2px 0px #888 inset;
  }

  .dpad-left {
    top: 33%; left: 4px;
    border: 4px solid black; border-right: none;
    border-radius: 5px 0 0 5px;
    box-shadow: 0px -2px 0px #888 inset;
  }

  .dpad-middle {
    width: 33%; height: 33%;
    position: absolute;
    top: 33%; left: 33%;
    background-color: #565e6a;
    z-index: -5;
  }

  .dpad-middle::after {
    content: '';
    position: absolute;
    top: 20%; left: 20%;
    width: 60%; height: 60%;
    border: 1px solid #6e737a;
    background: linear-gradient(to bottom, #6d7075 0%, #6d7075 30%, #23272f 70%, #23272f 100%);
    border-radius: 50%;
  }

  .ab-group {
    position: relative;
    display: inline-block;
    width: 120px;
    height: 90px;
  }

  .btn-a, .btn-b {
    position: absolute;
    font-size: 22px;
    width: 40px;
    height: 40px;
    line-height: 40px;
    border-radius: 50%;
    background-color: #2c313e;
    border-bottom: 2px solid #888;
    box-shadow: -1px 1px 5px black, 0px 0px 5px black inset;
    text-shadow: 0px -1px 1px #888;
    color: #2c313e;
    text-align: center;
    cursor: pointer;
    transition: box-shadow 0.1s ease-out, border 0.1s ease-out, line-height 0.2s ease-out;
  }

  .btn-a:active, .btn-b:active {
    box-shadow: -1px 1px 1px black, 0px 0px 5px black inset;
    border-width: 0;
    line-height: 45px;
  }

  .btn-a { top: 15px; right: 10px; }
  .btn-b { top: 35px; left: 0; }

  /* ─────────────────────────────────────────────────
     START / SELECT
  ───────────────────────────────────────────────── */
  .start-select {
    width: 100%;
    height: 60px;
    display: flex;
    justify-content: center;
  }

  .btn-select, .btn-start {
    display: inline-block;
    color: #6b67ed;
    text-shadow: 0px -1px 0px #3436bf;
    letter-spacing: -1px;
    width: 60px;
    font-size: 16px;
    text-align: center;
    margin-top: 60px;
  }

  .btn-select::before, .btn-start::before {
    content: '';
    display: block;
    margin: 0 auto 5px;
    width: 30px;
    height: 10px;
    border-radius: 40%;
    background: linear-gradient(to bottom, #0b0a1c 0%, #0b0a1c 30%, #62636c 70%, #62636c 100%);
    border: 2px solid #0b0a1c;
    box-shadow: 0px -2px 1px #8482e9;
    cursor: pointer;
  }

  .btn-select:active::before, .btn-start:active::before {
    background: linear-gradient(to bottom, #0b0a1c 0%, #0b0a1c 50%, #62636c 100%);
  }

  /* ─────────────────────────────────────────────────
     Speaker grille
  ───────────────────────────────────────────────── */
  .speaker {
    position: absolute;
    display: flex;
    width: 75px;
    height: 75px;
    right: 15px;
    bottom: 5px;
    justify-content: space-between;
    flex-wrap: wrap;
    z-index: 100;
    transform: skewY(-10deg);
  }

  .dot {
    width: 7px;
    height: 7px;
    margin: 1px;
    border-radius: 50%;
  }

  .dot-placeholder { background-color: transparent; }

  .dot-open {
    background-color: #0a0717;
    box-shadow: 0px 0px 2px #7c7be0 inset;
  }

  .dot-closed {
    background: linear-gradient(to bottom, #6664e5 0%, #2d3590 100%);
    box-shadow: 0px 0px 2px #7c7be0 inset;
  }
</style>

<script is:inline>
(function () {
  var PING_MS = 1650; // logo settles at 1100ms + 550ms animation

  function playPing(audioCtx) {
    var t = audioCtx.currentTime;
    var osc  = audioCtx.createOscillator();
    var gain = audioCtx.createGain();
    osc.connect(gain);
    gain.connect(audioCtx.destination);

    osc.type = 'square';
    osc.frequency.setValueAtTime(1318.5, t);                      // E6 — bright attack
    osc.frequency.exponentialRampToValueAtTime(659.25, t + 0.06); // E5 — body

    gain.gain.setValueAtTime(0.0001, t);
    gain.gain.linearRampToValueAtTime(0.13, t + 0.015);
    gain.gain.setValueAtTime(0.13, t + 0.08);
    gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.8);

    osc.start(t);
    osc.stop(t + 0.8);
  }

  function init() {
    var powerBtn = document.querySelector('.gb-wrap .power');
    var gbWrap   = document.querySelector('.gb-wrap');
    if (!powerBtn || !gbWrap) return;

    powerBtn.addEventListener('click', function onPowerClick() {
      powerBtn.removeEventListener('click', onPowerClick);

      // 1. Start visual boot sequence
      gbWrap.classList.add('is-on');

      // 2. Play audio — AudioContext created inside click handler (user gesture ✓)
      try {
        var audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        audioCtx.resume().then(function () {
          setTimeout(function () { playPing(audioCtx); }, PING_MS);
        });
      } catch (e) {}
    });
  }

  // DOM is already available since script is at end of component
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
