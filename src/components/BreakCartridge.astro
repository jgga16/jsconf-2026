---
import { formatTimeRange } from '../lib/talks';
import type { TalkWithAssets, BreakType } from '../types/talk';

type Props = {
  talk: TalkWithAssets;
};

const { talk } = Astro.props;

type BreakVariant = {
  icon: string;
  label: string;
  base: string;
  dark: string;
  darker: string;
  labelStart: string;
  labelEnd: string;
  glow: string;
  iconBg: string;
  iconFg: string;
  energy: string;
  energyPct: number;
  tagline: string;
};

const BREAK_VARIANTS: Record<BreakType, BreakVariant> = {
  coffee: {
    icon: '☕',
    label: 'Coffee Boost',
    base: '#4a9d5f',
    dark: '#3c7c4c',
    darker: '#2f623c',
    labelStart: '#1d3c28',
    labelEnd: '#0f2317',
    glow: '#7be09a',
    iconBg: '#164228',
    iconFg: '#d8f6e0',
    energy: '#7be09a',
    energyPct: 82,
    tagline: 'Cafeína + pixeles para seguir jugando.',
  },
  breakfast: {
    icon: '🥐',
    label: 'Breakfast Buff',
    base: '#e8b84d',
    dark: '#c7941f',
    darker: '#8b6615',
    labelStart: '#5f3a08',
    labelEnd: '#3b2404',
    glow: '#ffe9a3',
    iconBg: '#4d3006',
    iconFg: '#fff4c2',
    energy: '#ffd66b',
    energyPct: 76,
    tagline: 'Dale fuel al cerebro antes del boss.',
  },
  lunch: {
    icon: '🥪',
    label: 'Lunch Restore',
    base: '#d84a4a',
    dark: '#ae2f2f',
    darker: '#7a2020',
    labelStart: '#3a0f0f',
    labelEnd: '#200707',
    glow: '#ffc8c8',
    iconBg: '#2b0b0b',
    iconFg: '#ffe0e0',
    energy: '#ff9c9c',
    energyPct: 90,
    tagline: 'Recarga HP completa antes del siguiente nivel.',
  },
  networking: {
    icon: '⭐',
    label: 'Network Star',
    base: '#8a5aa8',
    dark: '#6c4088',
    darker: '#48295e',
    labelStart: '#2c1c38',
    labelEnd: '#1a1022',
    glow: '#d7b5ff',
    iconBg: '#201329',
    iconFg: '#f7e8ff',
    energy: '#d7b5ff',
    energyPct: 70,
    tagline: 'Haz respawn de contactos legendarios.',
  },
  generic: {
    icon: '❤️',
    label: 'Energy Up',
    base: '#3b6db7',
    dark: '#2c528a',
    darker: '#1f3a63',
    labelStart: '#102038',
    labelEnd: '#0c1626',
    glow: '#a5c8ff',
    iconBg: '#0d1a2d',
    iconFg: '#e3efff',
    energy: '#8db9ff',
    energyPct: 64,
    tagline: 'Recarga continua entre misiones.',
  },
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const placeholder = `${base}/placeholders/avatar.svg`;

const breakType = (talk.breakType ?? 'generic') as BreakType;
const variant = BREAK_VARIANTS[breakType] ?? BREAK_VARIANTS.generic;
const timeLabel = talk.time ? formatTimeRange(talk.time.start, talk.time.end) : '';
const description = talk.description?.trim() || variant.tagline;
---

<article
  class="card-wrap"
  data-talk-id={talk.id}
  data-avatar={placeholder}
  data-speaker={talk.title}
  data-time-start={talk.time?.start}
  data-time-end={talk.time?.end}
  style={`--c-base:${variant.base};--c-dark:${variant.dark};--c-darker:${variant.darker};--c-label-start:${variant.labelStart};--c-label-end:${variant.labelEnd};--c-glow:${variant.glow};--c-icon-bg:${variant.iconBg};--c-icon-fg:${variant.iconFg};--c-energy:${variant.energy};--energy-pct:${variant.energyPct}%`}
>
  <div class="cartridge">
    <div class="case">

      <!-- Front face -->
      <div class="front">
        <div class="base tall"></div>
        <div class="base wide"></div>
        <div class="linebase"></div>
        <div class="line one"></div>
        <div class="line two"></div>
        <div class="line three"></div>
        <div class="line four"></div>
        <div class="leftindent"></div>
        <div class="rightindent"></div>
        <div class="oval"></div>
        <div class="label">
          <div class="label-top">
            <div class="power-pill">
              <span class="powerup-icon" aria-hidden="true">{variant.icon}</span>
              <span class="powerup-type">{variant.label}</span>
            </div>
            <span class="rev">{timeLabel}</span>
          </div>
          <p class="break-title">{talk.title}</p>
          <p class="break-sub">{description}</p>
          <div class="energy-bar">
            <span class="energy-fill"></span>
            <span class="energy-label">ENERGÍA +{variant.energyPct}</span>
          </div>
        </div>
      </div>

      <!-- Back face -->
      <div class="back">
        <div class="base tall"></div>
        <div class="base wide"></div>
        <div class="line one"></div>
        <div class="line two"></div>
        <div class="line three"></div>
        <div class="line four"></div>
      </div>

      <!-- Right side -->
      <div class="rightside">
        <div class="top"></div>
        <div class="bottom"></div>
        <div class="line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Left side -->
      <div class="leftside">
        <div class="bottom"></div>
        <div class="line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Top side -->
      <div class="topside">
        <div class="left"></div>
        <div class="right"></div>
      </div>

      <!-- Bottom side -->
      <div class="bottomside">
        <div class="side"></div>
      </div>

    </div>
  </div>
</article>

<style>
  /* ── Dimensions & palette (scoped to component) ───── */
  .card-wrap {
    --cw: 196px;
    --ch: 225px;   /* cw × 1.15 */
    --cd: 20px;    /* cw × 0.1  */
    --cd2: 10px;   /* cd / 2    */

    --c-base:    #a7a9ac;
    --c-dark:    #939598;
    --c-darker:  #828487;
    --c-label-start: #22375e;
    --c-label-end: #0f1a30;
    --c-glow: #c8f0b0;
    --c-icon-bg: #0c1626;
    --c-icon-fg: #e3efff;
    --c-energy: #9ad38a;
  }

  /* ── Cell wrapper ─────────────────────────────────── */
  .card-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 24px 36px;   /* room for 3D overflow + tilt */
  }

  /* ── Cartridge container ──────────────────────────── */
  .cartridge {
    position: relative;
    display: inline-block;
    width: var(--cw);
    height: var(--ch);
    perspective: 900px;
    transform-style: preserve-3d;
    flex-shrink: 0;
  }

  .case {
    position: absolute;
    height: 100%;
    width: 100%;
    transform-style: preserve-3d;
    /* Show front + right edge by default */
    transform: rotateY(-22deg) rotateX(10deg);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card-wrap:hover .case {
    transform: rotateY(-8deg) rotateX(4deg);
  }

  /* ── Front / Back ─────────────────────────────────── */
  .front,
  .back {
    display: block;
    position: absolute;
    height: 100%;
    width: 100%;
  }

  .front .base,
  .back .base {
    background-color: var(--c-base);
    position: absolute;
  }

  .front .tall,
  .back .tall {
    height: 50%;
    width: 90%;
    top: 0;
    left: 0;
  }

  .front .wide,
  .back .wide {
    height: 95%;
    width: 100%;
    bottom: 0;
    right: 0;
  }

  /* Horizontal stripe with grooves */
  .front .linebase {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: 15%;
    top: 9%;
    left: 0;
  }

  .front .line,
  .back .line {
    position: absolute;
    background-color: var(--c-base);
    width: 104%;
    left: -2%;
    height: calc(15% / 9);
  }

  /* Vertical indent rails */
  .front .leftindent,
  .front .rightindent {
    position: absolute;
    height: 65%;
    width: 2%;
    bottom: 0;
    background-color: var(--c-dark);
  }

  .front .rightindent {
    right: 0;
  }

  /* Top oval cutout */
  .front .oval {
    position: absolute;
    width: 75%;
    height: 15%;
    background-color: var(--c-dark);
    border: calc(var(--cw) / 50) solid var(--c-base);
    border-radius: 9999px;
    left: calc(12.5% - 2%);
    top: 7%;
  }

  /* ── Label (break content area) ─────────────────── */
  .front .label {
    position: absolute;
    height: calc(var(--cw) * 0.75);
    width: 70%;
    bottom: 7%;
    left: calc(15% - 1%);
    border: calc(var(--cw) / 100) solid rgba(0, 0, 0, 0.4);
    border-radius: calc(var(--cw) / 50);
    overflow: hidden;
    padding: 8px;
    background:
      linear-gradient(160deg, var(--c-label-start) 0%, var(--c-label-end) 100%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.06),
      0 0 8px rgba(0, 0, 0, 0.4),
      0 0 16px 2px color-mix(in srgb, var(--c-glow) 40%, transparent);
  }

  .label-top {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .power-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--c-icon-bg);
    color: var(--c-icon-fg);
    padding: 6px 8px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.35);
  }

  .powerup-icon {
    font-size: 2.4rem;
    line-height: 1;
    text-shadow:
      0 0 0 currentColor,
      -2px 0 currentColor,
      2px 0 currentColor,
      0 -2px currentColor,
      0 2px currentColor,
      -2px -2px currentColor,
      2px -2px currentColor,
      -2px 2px currentColor,
      2px 2px currentColor;
  }

  .powerup-type {
    font-family: var(--font-display);
    font-size: 0.58rem;
    letter-spacing: 0.04em;
  }

  .break-title {
    flex: 1;
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.2;
    color: #fdfdfd;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.55);
  }

  .break-sub {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: color-mix(in srgb, var(--c-glow) 70%, #ffffff 20%);
    letter-spacing: 0.03em;
  }

  .energy-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }

  .energy-fill {
    position: relative;
    display: block;
    width: 100%;
    height: 10px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 2px 0 rgba(255, 255, 255, 0.06);
  }

  .energy-fill::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: var(--energy-pct);
    max-width: 100%;
    background: linear-gradient(90deg, var(--c-energy), color-mix(in srgb, var(--c-energy) 70%, #ffffff 30%));
    box-shadow: 0 0 10px color-mix(in srgb, var(--c-energy) 60%, transparent);
  }

  .energy-label {
    font-family: var(--font-display);
    font-size: 0.58rem;
    color: color-mix(in srgb, var(--c-energy) 80%, #ffffff 10%);
    white-space: nowrap;
  }

  .rev {
    font-family: var(--font-display);
    font-size: 0.58rem;
    background: color-mix(in srgb, var(--c-icon-bg) 60%, #000000 20%);
    color: var(--c-glow);
    padding: 4px 6px;
    border: 1px solid rgba(0, 0, 0, 0.45);
    box-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ── translateZ for front/back ────────────────────── */
  .front {
    transform: translateZ(var(--cd2));
  }

  .back {
    transform: translateZ(calc(-1 * var(--cd2)));
  }

  /* ── Groove line positions (shared by front, back, sides) */
  .one   { top: calc(9% + (15% / 9) * 1); }
  .two   { top: calc(9% + (15% / 9) * 3); }
  .three { top: calc(9% + (15% / 9) * 5); }
  .four  { top: calc(9% + (15% / 9) * 7); }

  /* ── Right / Left sides ───────────────────────────── */
  .rightside,
  .leftside {
    position: absolute;
    width: var(--cd);
    height: 100%;
    bottom: 0;
    transform-style: preserve-3d;
    transform: rotateY(90deg);
  }

  .rightside {
    right: calc(-1 * var(--cd2));
  }

  .leftside {
    left: calc(-1 * var(--cd2));
  }

  .rightside .top {
    position: absolute;
    background-color: var(--c-darker);
    width: 100%;
    height: 5%;
    transform: translateZ(calc(-1 * var(--cd)));
  }

  .rightside .bottom,
  .leftside .bottom {
    position: absolute;
    bottom: 0;
    background-color: var(--c-dark);
    width: 100%;
  }

  .rightside .bottom { height: 95%; }
  .leftside  .bottom { height: 100%; }

  .rightside .line,
  .leftside .line {
    position: absolute;
    background-color: var(--c-darker);
    height: calc(15% / 9);
    width: 100%;
  }

  .rightside .line { transform: translateZ(calc(var(--cw) * 0.02)); }
  .leftside  .line { transform: translateZ(calc(-1 * var(--cw) * 0.02)); }

  .rightside .floor,
  .rightside .ceiling,
  .leftside .floor,
  .leftside .ceiling {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: calc(var(--cw) * 0.04);
    transform: rotateX(90deg);
  }

  .rightside .ceiling,
  .leftside .ceiling {
    transform: translateY(calc(-1 * var(--ch) * 0.15 / 9)) rotateX(90deg);
  }

  /* ── Top side ─────────────────────────────────────── */
  .topside {
    position: absolute;
    width: 100%;
    height: var(--cd);
    top: calc(-1 * var(--cd2));
    transform: rotateX(90deg);
    transform-style: preserve-3d;
  }

  .topside .left {
    position: absolute;
    background-color: var(--c-dark);
    width: 90%;
    height: 100%;
  }

  .topside .right {
    position: absolute;
    background-color: var(--c-darker);
    width: 10%;
    height: 100%;
    right: 0;
    transform: translateZ(calc(-1 * var(--ch) * 0.05));
  }

  /* ── Bottom side (connector edge) ────────────────── */
  .bottomside {
    position: absolute;
    background-color: #1e1e1e;
    bottom: calc(-1 * var(--cd2));
    height: calc(var(--cd) / 2);
    width: calc(var(--cw) - var(--cd2));
    transform: rotateX(90deg);
    border: calc(var(--cw) * 0.025) solid var(--c-darker);
  }
</style>
