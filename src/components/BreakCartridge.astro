---
import { formatTimeRange } from '../lib/talks';
import type { BreakCategory, TalkWithAssets } from '../types/talk';

type Props = {
  talk: TalkWithAssets;
};

const { talk } = Astro.props;

const paletteByCategory: Record<
  BreakCategory | 'default',
  {
    shell: string;
    shellDark: string;
    label: string;
    accent: string;
    glow: string;
    badge: string;
    effect: string;
    fill: number;
    icon: 'coffee' | 'croissant' | 'heart' | 'potion';
  }
> = {
  coffee: {
    shell: '#2f7d48',
    shellDark: '#1f5733',
    label: '#0c1d15',
    accent: '#d9ffbe',
    glow: 'rgba(66, 160, 110, 0.6)',
    badge: '#b7f5c2',
    effect: 'CAFFEINE BOOST',
    fill: 82,
    icon: 'coffee',
  },
  breakfast: {
    shell: '#f2b705',
    shellDark: '#c48800',
    label: '#2b1302',
    accent: '#fff5c2',
    glow: 'rgba(255, 203, 87, 0.6)',
    badge: '#ffe7a3',
    effect: 'SUNRISE START',
    fill: 76,
    icon: 'croissant',
  },
  lunch: {
    shell: '#d12f45',
    shellDark: '#961e30',
    label: '#24050b',
    accent: '#ffd6d9',
    glow: 'rgba(209, 47, 69, 0.55)',
    badge: '#ffb0b9',
    effect: 'FULL RESTORE',
    fill: 96,
    icon: 'heart',
  },
  networking: {
    shell: '#6e3ce4',
    shellDark: '#4d28a8',
    label: '#0d0a26',
    accent: '#ead8ff',
    glow: 'rgba(128, 92, 247, 0.65)',
    badge: '#d0b5ff',
    effect: 'SOCIAL XP UP',
    fill: 88,
    icon: 'potion',
  },
  default: {
    shell: '#2c3e50',
    shellDark: '#1e2935',
    label: '#0d1420',
    accent: '#cde5ff',
    glow: 'rgba(70, 130, 180, 0.5)',
    badge: '#b8d4ff',
    effect: 'ENERGY BOOST',
    fill: 78,
    icon: 'coffee',
  },
};

const category = talk.breakCategory ?? 'coffee';
const palette = paletteByCategory[category] ?? paletteByCategory.default;
const timeRange = formatTimeRange(talk.time.start, talk.time.end);
const flavor = talk.description?.trim();
const iconName = palette.icon;
---

<article
  class="card-wrap break-card"
  data-time-start={talk.time.start}
  data-time-end={talk.time.end}
  aria-label={`${talk.title} — ${palette.effect}`}
  style={`--shell:${palette.shell}; --shell-dark:${palette.shellDark}; --label:${palette.label}; --accent:${palette.accent}; --glow:${palette.glow}; --badge:${palette.badge}; --fill:${palette.fill}%;`}
>
  <div class="power-shell">
    <div class="ridge"></div>
    <div class="ridge shadow"></div>
    <div class="label">
      <div class="label-top">
        <span class="badge">POWER-UP</span>
        <span class="time">{timeRange}</span>
      </div>
      <div class="icon-plate" aria-hidden="true">
        <div class="burst burst-1"></div>
        <div class="burst burst-2"></div>
        {iconName === 'coffee' ? (
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <rect x="4" y="4" width="1" height="2" fill="#b7f5c2" />
            <rect x="6" y="3" width="1" height="3" fill="#b7f5c2" />
            <rect x="8" y="4" width="1" height="2" fill="#b7f5c2" />
            <rect x="4" y="6" width="7" height="7" fill="#f7f1e8" />
            <rect x="3" y="7" width="9" height="5" fill="#f7f1e8" />
            <rect x="11" y="7" width="2" height="3" fill="#f7f1e8" />
            <rect x="12" y="8" width="1" height="1" fill="#cfb69b" />
            <rect x="4" y="10" width="6" height="2" fill="#c1926a" />
            <rect x="4" y="12" width="7" height="1" fill="#8a6645" />
            <rect x="3" y="6" width="9" height="1" fill="#d8c7b5" />
            <rect x="5" y="11" width="1" height="1" fill="#ffffff" />
          </svg>
        ) : iconName === 'croissant' ? (
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <rect x="5" y="6" width="6" height="4" fill="#f6d287" />
            <rect x="4" y="7" width="8" height="2" fill="#f9e2ac" />
            <rect x="3" y="8" width="10" height="1" fill="#f9c86f" />
            <rect x="4" y="9" width="2" height="2" fill="#e4a64d" />
            <rect x="10" y="9" width="2" height="2" fill="#e4a64d" />
            <rect x="6" y="5" width="1" height="1" fill="#fef4d4" />
            <rect x="9" y="5" width="1" height="1" fill="#fef4d4" />
            <rect x="6" y="10" width="4" height="1" fill="#c47a26" />
          </svg>
        ) : iconName === 'heart' ? (
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <rect x="4" y="5" width="3" height="3" fill="#ff9fb3" />
            <rect x="9" y="5" width="3" height="3" fill="#ff9fb3" />
            <rect x="4" y="8" width="8" height="3" fill="#ff2f4d" />
            <rect x="5" y="11" width="6" height="2" fill="#d01632" />
            <rect x="6" y="13" width="4" height="1" fill="#8b0e21" />
            <rect x="5" y="6" width="1" height="1" fill="#ffd6df" />
            <rect x="10" y="6" width="1" height="1" fill="#ffd6df" />
          </svg>
        ) : (
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <rect x="7" y="1" width="2" height="3" fill="#d0b5ff" />
            <rect x="6" y="4" width="4" height="1" fill="#c4a1ff" />
            <rect x="6" y="5" width="4" height="2" fill="#6f3ae3" />
            <rect x="5" y="7" width="6" height="6" fill="#9052ff" />
            <rect x="4" y="8" width="8" height="4" fill="#b27bff" />
            <rect x="4" y="12" width="8" height="2" fill="#4c1dbd" />
            <rect x="5" y="10" width="2" height="1" fill="#d7c9ff" />
            <rect x="9" y="11" width="1" height="1" fill="#eadcff" />
          </svg>
        )}
      </div>
      <h3 class="title">{talk.title}</h3>
      <p class="effect">{palette.effect}</p>
      <div class="meter" role="presentation">
        <div class="meter-fill"></div>
      </div>
      {flavor ? <p class="flavor">{flavor}</p> : null}
    </div>
  </div>
</article>

<style>
  .break-card {
    --cw: 196px;
    --ch: 225px;
    --shell: #2f7d48;
    --shell-dark: #1f5733;
    --label: #0c1d15;
    --accent: #d9ffbe;
    --glow: rgba(66, 160, 110, 0.6);
    --badge: #b7f5c2;
    --fill: 82%;
  }

  .power-shell {
    position: relative;
    width: var(--cw);
    height: var(--ch);
    background: linear-gradient(160deg, var(--shell) 0%, var(--shell-dark) 95%);
    border: 3px solid var(--shell-dark);
    border-radius: 10px;
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.14),
      inset 0 -3px 0 rgba(0, 0, 0, 0.2),
      0 12px 18px rgba(0, 0, 0, 0.35),
      0 0 24px var(--glow);
    padding: 14px 12px 12px;
    overflow: hidden;
  }

  .power-shell::after {
    content: '';
    position: absolute;
    inset: 10px;
    border-radius: 6px;
    border: 2px dashed rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }

  .ridge {
    position: absolute;
    top: 6px;
    left: 14px;
    right: 14px;
    height: 10px;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.15), rgba(255, 255, 255, 0.12));
    border-radius: 6px;
    z-index: 1;
  }

  .ridge.shadow {
    top: 12px;
    filter: blur(1px);
    opacity: 0.3;
  }

  .label {
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, var(--label) 0%, #060b16 100%);
    border: 2px solid rgba(0, 0, 0, 0.35);
    border-radius: 8px;
    padding: 12px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 4px 0 rgba(0, 0, 0, 0.4);
  }

  .label-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    background: var(--badge);
    color: #1b0d02;
    border: 2px solid rgba(0, 0, 0, 0.25);
    box-shadow:
      inset 0 -2px 0 rgba(0, 0, 0, 0.15),
      2px 2px 0 rgba(0, 0, 0, 0.35);
    text-transform: uppercase;
  }

  .time {
    font-family: var(--font-display);
    font-size: 0.72rem;
    color: var(--accent);
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    letter-spacing: 0.05em;
  }

  .icon-plate {
    position: relative;
    display: grid;
    place-items: center;
    padding: 16px;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.06), transparent 60%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 65%),
      rgba(0, 0, 0, 0.35);
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .icon-plate::after {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: 6px;
  }

  .burst {
    position: absolute;
    width: 90%;
    height: 90%;
    border-radius: 999px;
    background: radial-gradient(circle, var(--glow), transparent 60%);
    filter: blur(6px);
    opacity: 0.45;
  }

  .burst-2 {
    transform: rotate(35deg);
    opacity: 0.3;
  }

  .icon-plate svg {
    width: 74px;
    height: 74px;
    image-rendering: pixelated;
    z-index: 1;
  }

  .title {
    margin: 2px 0 0;
    font-family: var(--font-display);
    font-size: 0.94rem;
    line-height: 1.25;
    color: #f8f0ff;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
  }

  .effect {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--accent);
  }

  .meter {
    height: 12px;
    border-radius: 6px;
    border: 2px solid var(--shell-dark);
    background: #0a0f18;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.04),
      0 2px 0 rgba(0, 0, 0, 0.35);
    overflow: hidden;
  }

  .meter-fill {
    width: var(--fill);
    height: 100%;
    background: repeating-linear-gradient(
      90deg,
      var(--accent) 0,
      var(--accent) 10px,
      rgba(0, 0, 0, 0) 10px,
      rgba(0, 0, 0, 0) 12px
    );
    box-shadow: 0 0 12px var(--glow);
  }

  .flavor {
    margin: 2px 0 0;
    font-family: var(--font-body);
    font-size: 0.74rem;
    line-height: 1.4;
    color: #d8e7ff;
    opacity: 0.92;
  }
</style>
