---
/*
 * Break Cartridge — Power-up style cartridge for breaks in the agenda.
 * Game Boy cartridge 3D shape inspired by CartridgeCard.astro.
 * Colors and icons reflect the break type (breakfast, coffee, lunch, networking).
 */
import type { TalkWithAssets } from '../types/talk';

type Props = {
  talk: TalkWithAssets;
};

const { talk } = Astro.props;

type BreakConfig = {
  powerUp: string;
  action: string;
  cssClass: string;
};

const breakConfigs: Record<string, BreakConfig> = {
  breakfast: {
    powerUp: '+500 XP',
    action: 'MORNING BOOST',
    cssClass: 'break-breakfast',
  },
  coffee: {
    powerUp: '+100 HP',
    action: 'ENERGY RELOAD',
    cssClass: 'break-coffee',
  },
  lunch: {
    powerUp: 'FULL HEAL',
    action: 'LIFE RESTORE',
    cssClass: 'break-lunch',
  },
  networking: {
    powerUp: 'BONUS STAGE',
    action: 'SOCIAL XP ×2',
    cssClass: 'break-networking',
  },
};

/*
 * Pixel-art icons defined as arrays of {x,y,w,h} rects on an 8×8 grid.
 * Rendered as inline SVG so they inherit `currentColor` from CSS.
 *
 *  breakfast  → 4-pointed star  (morning star / energy)
 *  coffee     → lightning bolt  (quick boost / recharge)
 *  lunch      → heart           (classic RPG health restore)
 *  networking → trophy cup      (bonus stage / achievement)
 */
type Rect = { x: number; y: number; w: number; h: number };
const pixelIcons: Record<string, Rect[]> = {
  breakfast: [
    // 4-pointed star
    { x: 3, y: 0, w: 2, h: 2 },
    { x: 2, y: 2, w: 4, h: 1 },
    { x: 0, y: 3, w: 8, h: 2 },
    { x: 2, y: 5, w: 4, h: 1 },
    { x: 3, y: 6, w: 2, h: 2 },
  ],
  coffee: [
    // lightning bolt (top-right to bottom-left)
    { x: 3, y: 0, w: 4, h: 1 },
    { x: 2, y: 1, w: 4, h: 1 },
    { x: 1, y: 2, w: 4, h: 1 },
    { x: 2, y: 3, w: 2, h: 1 },
    { x: 3, y: 4, w: 3, h: 1 },
    { x: 4, y: 5, w: 3, h: 1 },
    { x: 5, y: 6, w: 2, h: 1 },
  ],
  lunch: [
    // classic heart
    { x: 1, y: 0, w: 2, h: 1 },
    { x: 4, y: 0, w: 2, h: 1 },
    { x: 0, y: 1, w: 7, h: 2 },
    { x: 1, y: 3, w: 6, h: 1 },
    { x: 2, y: 4, w: 4, h: 1 },
    { x: 3, y: 5, w: 2, h: 1 },
  ],
  networking: [
    // trophy cup
    { x: 0, y: 0, w: 8, h: 1 },
    { x: 0, y: 1, w: 1, h: 2 },
    { x: 7, y: 1, w: 1, h: 2 },
    { x: 1, y: 3, w: 6, h: 1 },
    { x: 2, y: 4, w: 4, h: 1 },
    { x: 3, y: 5, w: 2, h: 1 },
    { x: 1, y: 6, w: 6, h: 1 },
  ],
};

const breakType = talk.breakType ?? 'coffee';
const cfg = breakConfigs[breakType];
const timeLabel = talk.time?.start ?? '';
const timeEnd = talk.time?.end ?? '';
---

<article
  class={`break-card-wrap ${cfg.cssClass}`}
  aria-label={`${talk.title} — ${timeLabel}–${timeEnd}`}
  data-break-type={breakType}
>
  <div class="cartridge">
    <div class="case">

      <!-- Front face -->
      <div class="front">
        <div class="base tall"></div>
        <div class="base wide"></div>
        <div class="linebase"></div>
        <div class="line one"></div>
        <div class="line two"></div>
        <div class="line three"></div>
        <div class="line four"></div>
        <div class="leftindent"></div>
        <div class="rightindent"></div>
        <div class="oval"></div>
        <div class="label">
          <div class="powerup-header">POWER-UP!</div>
          <svg
            class="powerup-icon"
            viewBox="0 0 8 8"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            {(pixelIcons[breakType] ?? pixelIcons.coffee).map((r) => (
              <rect x={r.x} y={r.y} width={r.w} height={r.h} fill="currentColor" />
            ))}
          </svg>
          <div class="powerup-value">{cfg.powerUp}</div>
          <p class="break-title">{talk.title}</p>
          <div class="label-bottom">
            <span class="powerup-action">{cfg.action}</span>
            <span class="rev">{timeLabel}</span>
          </div>
        </div>
      </div>

      <!-- Back face -->
      <div class="back">
        <div class="base tall"></div>
        <div class="base wide"></div>
        <div class="line one"></div>
        <div class="line two"></div>
        <div class="line three"></div>
        <div class="line four"></div>
      </div>

      <!-- Right side -->
      <div class="rightside">
        <div class="top"></div>
        <div class="bottom"></div>
        <div class="line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Left side -->
      <div class="leftside">
        <div class="bottom"></div>
        <div class="line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Top side -->
      <div class="topside">
        <div class="left"></div>
        <div class="right"></div>
      </div>

      <!-- Bottom side -->
      <div class="bottomside">
        <div class="side"></div>
      </div>

    </div>
  </div>
</article>

<style>
  /* ── Dimensions & base palette ───────────────────────── */
  .break-card-wrap {
    --cw: 196px;
    --ch: 225px;
    --cd: 20px;
    --cd2: 10px;

    /* Default colours (overridden per variant below) */
    --c-base:         #2d5a2d;
    --c-dark:         #1e3e1e;
    --c-darker:       #142814;
    --c-label-from:   #1a3d1a;
    --c-label-to:     #0a200a;
    --c-icon:         #90e890;
    --c-powerup:      #60c860;
    --c-title:        #a8e8a8;
    --c-action:       #6aaa6a;
    --c-badge-bg:     #1a4a1a;
    --c-badge-text:   #a0f0a0;
    --c-badge-border: #0a280a;
  }

  /* ── Breakfast variant — Yellow / Gold ─────────────────── */
  .break-breakfast {
    --c-base:         #8a7020;
    --c-dark:         #6a5418;
    --c-darker:       #4a3c10;
    --c-label-from:   #5a4010;
    --c-label-to:     #3a2808;
    --c-icon:         #f8e060;
    --c-powerup:      #f5d040;
    --c-title:        #faeaa0;
    --c-action:       #c8a830;
    --c-badge-bg:     #6a5010;
    --c-badge-text:   #f8e870;
    --c-badge-border: #3a2c08;
  }

  /* ── Coffee break variant — Green ──────────────────────── */
  .break-coffee {
    --c-base:         #2d5a2d;
    --c-dark:         #1e3e1e;
    --c-darker:       #142814;
    --c-label-from:   #1a3d1a;
    --c-label-to:     #0a200a;
    --c-icon:         #90e890;
    --c-powerup:      #60c860;
    --c-title:        #a8e8a8;
    --c-action:       #6aaa6a;
    --c-badge-bg:     #1a4a1a;
    --c-badge-text:   #a0f0a0;
    --c-badge-border: #0a280a;
  }

  /* ── Lunch variant — Red ───────────────────────────────── */
  .break-lunch {
    --c-base:         #7a1a1a;
    --c-dark:         #5e1010;
    --c-darker:       #420808;
    --c-label-from:   #5a0f0f;
    --c-label-to:     #320606;
    --c-icon:         #f89090;
    --c-powerup:      #e84040;
    --c-title:        #f8b0b0;
    --c-action:       #c06060;
    --c-badge-bg:     #6a1010;
    --c-badge-text:   #f8a0a0;
    --c-badge-border: #3a0808;
  }

  /* ── Networking variant — Purple ───────────────────────── */
  .break-networking {
    --c-base:         #5a2a8a;
    --c-dark:         #3e1a6e;
    --c-darker:       #2c1050;
    --c-label-from:   #3a1060;
    --c-label-to:     #1e0838;
    --c-icon:         #c8a0f0;
    --c-powerup:      #a060e0;
    --c-title:        #d8b8f8;
    --c-action:       #8848c0;
    --c-badge-bg:     #4a1880;
    --c-badge-text:   #d0b0f8;
    --c-badge-border: #280848;
  }

  /* ── Cell wrapper ──────────────────────────────────────── */
  .break-card-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 24px 36px;
  }

  /* ── Cartridge container ───────────────────────────────── */
  .cartridge {
    position: relative;
    display: inline-block;
    width: var(--cw);
    height: var(--ch);
    perspective: 900px;
    transform-style: preserve-3d;
    flex-shrink: 0;
  }

  .case {
    position: absolute;
    height: 100%;
    width: 100%;
    transform-style: preserve-3d;
    transform: rotateY(-22deg) rotateX(10deg);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .break-card-wrap:hover .case {
    transform: rotateY(-8deg) rotateX(4deg);
  }

  /* ── Front / Back ──────────────────────────────────────── */
  .front,
  .back {
    display: block;
    position: absolute;
    height: 100%;
    width: 100%;
  }

  .front .base,
  .back .base {
    background-color: var(--c-base);
    position: absolute;
  }

  .front .tall,
  .back .tall {
    height: 50%;
    width: 90%;
    top: 0;
    left: 0;
  }

  .front .wide,
  .back .wide {
    height: 95%;
    width: 100%;
    bottom: 0;
    right: 0;
  }

  .front .linebase {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: 15%;
    top: 9%;
    left: 0;
  }

  .front .line,
  .back .line {
    position: absolute;
    background-color: var(--c-base);
    width: 104%;
    left: -2%;
    height: calc(15% / 9);
  }

  .front .leftindent,
  .front .rightindent {
    position: absolute;
    height: 65%;
    width: 2%;
    bottom: 0;
    background-color: var(--c-dark);
  }

  .front .rightindent {
    right: 0;
  }

  .front .oval {
    position: absolute;
    width: 75%;
    height: 15%;
    background-color: var(--c-dark);
    border: calc(var(--cw) / 50) solid var(--c-base);
    border-radius: 9999px;
    left: calc(12.5% - 2%);
    top: 7%;
  }

  /* ── Label (power-up content area) ─────────────────────── */
  .front .label {
    position: absolute;
    height: calc(var(--cw) * 0.75);
    width: 70%;
    bottom: 7%;
    left: calc(15% - 1%);
    border: calc(var(--cw) / 100) solid rgba(0, 0, 0, 0.4);
    border-radius: calc(var(--cw) / 50);
    overflow: hidden;
    padding: 8px;
    background: linear-gradient(160deg, var(--c-label-from) 0%, var(--c-label-to) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .powerup-header {
    font-family: var(--font-display);
    font-size: 0.38rem;
    color: var(--c-powerup);
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.7);
    letter-spacing: 0.04em;
    text-align: center;
    opacity: 0.9;
  }

  .powerup-icon {
    width: 40px;
    height: 40px;
    color: var(--c-icon);
    filter: drop-shadow(0 0 4px var(--c-icon)) drop-shadow(1px 1px 0 rgba(0, 0, 0, 0.6));
    image-rendering: pixelated;
    flex-shrink: 0;
    animation: powerup-pulse 2s ease-in-out infinite;
  }

  @keyframes powerup-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.75; transform: scale(0.95); }
  }

  .powerup-value {
    font-family: var(--font-display);
    font-size: 0.44rem;
    color: var(--c-powerup);
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.6);
    text-align: center;
    letter-spacing: 0.06em;
  }

  .break-title {
    flex: 1;
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.2;
    color: var(--c-title);
    text-align: center;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .label-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4px;
    width: 100%;
    margin-top: auto;
  }

  .powerup-action {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--c-action);
    line-height: 1.1;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .rev {
    font-family: var(--font-display);
    font-size: 0.42rem;
    background: var(--c-badge-bg);
    color: var(--c-badge-text);
    padding: 2px 6px;
    border: 1px solid var(--c-badge-border);
    box-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ── translateZ for front/back ─────────────────────────── */
  .front {
    transform: translateZ(var(--cd2));
  }

  .back {
    transform: translateZ(calc(-1 * var(--cd2)));
  }

  /* ── Groove line positions ─────────────────────────────── */
  .one   { top: calc(9% + (15% / 9) * 1); }
  .two   { top: calc(9% + (15% / 9) * 3); }
  .three { top: calc(9% + (15% / 9) * 5); }
  .four  { top: calc(9% + (15% / 9) * 7); }

  /* ── Right / Left sides ────────────────────────────────── */
  .rightside,
  .leftside {
    position: absolute;
    width: var(--cd);
    height: 100%;
    bottom: 0;
    transform-style: preserve-3d;
    transform: rotateY(90deg);
  }

  .rightside {
    right: calc(-1 * var(--cd2));
  }

  .leftside {
    left: calc(-1 * var(--cd2));
  }

  .rightside .top {
    position: absolute;
    background-color: var(--c-darker);
    width: 100%;
    height: 5%;
    transform: translateZ(calc(-1 * var(--cd)));
  }

  .rightside .bottom,
  .leftside .bottom {
    position: absolute;
    bottom: 0;
    background-color: var(--c-dark);
    width: 100%;
  }

  .rightside .bottom { height: 95%; }
  .leftside  .bottom { height: 100%; }

  .rightside .line,
  .leftside .line {
    position: absolute;
    background-color: var(--c-darker);
    height: calc(15% / 9);
    width: 100%;
  }

  .rightside .line { transform: translateZ(calc(var(--cw) * 0.02)); }
  .leftside  .line { transform: translateZ(calc(-1 * var(--cw) * 0.02)); }

  .rightside .floor,
  .rightside .ceiling,
  .leftside .floor,
  .leftside .ceiling {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: calc(var(--cw) * 0.04);
    transform: rotateX(90deg);
  }

  .rightside .ceiling,
  .leftside .ceiling {
    transform: translateY(calc(-1 * var(--ch) * 0.15 / 9)) rotateX(90deg);
  }

  /* ── Top side ──────────────────────────────────────────── */
  .topside {
    position: absolute;
    width: 100%;
    height: var(--cd);
    top: calc(-1 * var(--cd2));
    transform: rotateX(90deg);
    transform-style: preserve-3d;
  }

  .topside .left {
    position: absolute;
    background-color: var(--c-dark);
    width: 90%;
    height: 100%;
  }

  .topside .right {
    position: absolute;
    background-color: var(--c-darker);
    width: 10%;
    height: 100%;
    right: 0;
    transform: translateZ(calc(-1 * var(--ch) * 0.05));
  }

  /* ── Bottom side (connector edge) ──────────────────────── */
  .bottomside {
    position: absolute;
    background-color: #1e1e1e;
    bottom: calc(-1 * var(--cd2));
    height: calc(var(--cd) / 2);
    width: calc(var(--cw) - var(--cd2));
    transform: rotateX(90deg);
    border: calc(var(--cw) * 0.025) solid var(--c-darker);
  }
</style>
