---
import type { TalkWithAssets } from '../types/talk';
import { formatTimeRange } from '../lib/talks';

type Props = {
  talk: TalkWithAssets;
};

const { talk } = Astro.props;
const speaker = talk.speakers?.[0];

const time = formatTimeRange(talk.time.start, talk.time.end);

const coverSrc = talk.assets?.cover ?? '/placeholders/cover.svg';
const avatarSrc = talk.assets?.avatar8bit ?? '/placeholders/avatar.svg';

const roomLabel = talk.room ? `• ${talk.room}` : '';
const speakerLine = [speaker?.name, speaker?.role].filter(Boolean).join(' — ');
---

<article class="cartridge pixel-border">
  <div class="cover">
    <img class="cover-img" src={coverSrc} alt="" loading="lazy" decoding="async" />
    <img class="avatar" src={avatarSrc} alt={speaker?.name ? `${speaker.name} avatar` : 'Speaker avatar'} loading="lazy" decoding="async" />
  </div>

  <div class="body">
    <p class="meta"><span class="neon-cyan">{time}</span> {roomLabel}</p>

    <h2 class="title">{talk.title}</h2>

    <p class="speaker">{speakerLine || 'TBA'}</p>
  </div>
</article>

<style>
  .cartridge {
    background: linear-gradient(180deg, var(--panel), var(--panel2));
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    position: relative;
  }

  .cover {
    position: relative;
    aspect-ratio: 3 / 2;
    background: #0f0f0f;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: contrast(1.05) saturate(1.05);
  }

  .avatar {
    position: absolute;
    left: 12px;
    bottom: 12px;
    width: 64px;
    height: 64px;
    border-radius: 8px;
    background: #000;
    border: 3px solid rgba(0, 255, 255, 0.35);
    box-shadow: 0 0 18px rgba(0, 255, 255, 0.25);
    image-rendering: pixelated;
  }

  .body {
    padding: 14px 14px 18px;
  }

  .meta {
    margin: 0 0 10px;
    color: rgba(0, 255, 0, 0.85);
  }

  .title {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-size: 14px;
    line-height: 1.4;
  }

  .speaker {
    margin: 0;
    color: rgba(0, 255, 255, 0.85);
  }
</style>
